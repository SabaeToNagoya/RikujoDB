generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 選手
model Athlete {
  id           String    @id @default(cuid())
  nameKanji    String    // 氏名（漢字）
  nameFurigana String    // 氏名（ふりがな）
  dateOfBirth  DateTime?
  prefecture   String?   // 出身都道府県
  highSchool   String?   // 出身高校
  university   String?   // 出身大学
  teamId       String?   // 現在の所属チームID
  team         Team?     @relation("AthleteTeam", fields: [teamId], references: [id], onDelete: SetNull)
  gender       String    // 男性 / 女性
  notes        String?   // 備考

  records      Record[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// チーム
model Team {
  id        String       @id @default(cuid())
  name      String
  type      String       // 実業団 / 大学 / 高校
  notes     String?

  athletes  Athlete[]    @relation("AthleteTeam") // このチームに所属する選手
  records   Record[]     // このチームに紐づく記録
  results   TeamResult[]

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// 競技記録
model Record {
  id              String    @id @default(cuid())
  athleteId       String
  athlete         Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  teamId          String?   // 記録当時の所属チームID（任意）
  team            Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  event           String    // 種目
  timeString      String    // タイム（表示用: 2:06:35）
  timeSeconds     Int       // タイム（ソート用: 秒換算）
  competitionName String    // 大会名
  date            DateTime  // 開催日
  ranking         String?   // 順位（任意: "1位", "銅", "5位" など）
  notes           String?   // 備考（自己ベスト・区間新など）

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// チーム成績
model TeamResult {
  id              String    @id @default(cuid())
  teamId          String
  team            Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  competitionName String    // 大会名
  type            String    // 駅伝 / マラソン団体戦 等
  year            Int       // 開催年
  ranking         Int       // 順位
  totalTime       String?   // 合計タイム
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// 観戦セットアップ
model WatchingSetup {
  id         String    @id @default(cuid())
  name       String    // セットアップ名
  type       String    // individual / ekiden
  athleteIds String    // JSON配列: ["athleteId1", "athleteId2", ...]
  teamSetup  String?   // JSON: [{teamId, segments: [{segmentNo, athleteId}]}]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
